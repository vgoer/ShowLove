# ========== Show Love 环境变量模板 ==========

# JWT 密钥（必填，生产环境请使用随机生成的密钥）
JWT_SECRET=change-me-to-a-random-secret

# ========== 数据库 ==========
POSTGRES_USER=showlove
POSTGRES_PASSWORD=showlove123
POSTGRES_DB=showlove

# ========== Redis ==========
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ========== MinIO (S3 兼容存储) ==========
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=showlove
MINIO_USE_SSL=false

# ========== RustFS (SeaweedFS, 备选存储) ==========
# STORAGE_PROVIDER=rustfs
# RUSTFS_MASTER=localhost:9333
# RUSTFS_FILER=localhost:8888

# ========== AI 模型配置 ==========
# 可选: openai | deepseek | qwen | ollama
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
QWEN_API_KEY=sk-your-qwen-api-key
OLLAMA_BASE_URL=http://localhost:11434

# ========== NATS ==========
NATS_URL=nats://localhost:4222

# ========== FCM 推送 ==========
# FCM_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# ========== 服务地址（Docker 内部网络） ==========
USER_SVC_ADDR=localhost:50051
POST_SVC_ADDR=localhost:50052
COMMENT_SVC_ADDR=localhost:50053
MOOD_SVC_ADDR=localhost:50054
QUOTE_SVC_ADDR=localhost:50055
AI_SVC_ADDR=localhost:50056
NOTIFICATION_SVC_ADDR=localhost:50057

# ========== 日志 ==========
LOG_LEVEL=debug

# ========== 网关 ==========
GIN_MODE=debug
GATEWAY_PORT=8080
